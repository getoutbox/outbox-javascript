{
  "name": "@outbox-sdk/outbox",
  "version": "0.1.0",
  "description": "Outbox Human Interaction SDK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getoutbox/outbox-javascript.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@connectrpc/connect": "catalog:",
    "@connectrpc/connect-web": "catalog:"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  }
}
